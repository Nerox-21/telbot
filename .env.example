# ============================================================================
#  کپی کنید از این فایل به .env  و مقادیر را پر کنید:   cp .env.example .env
# ============================================================================

# --- ربات تلگرام ---
# توکن ربات را از @BotFather بگیرید
BOT_TOKEN=8634441121:AAGgnPJSphEihGPTkgYAOduOiQS2zlotKp4

# آیدی عددی ادمین‌ها (با کاما جدا کنید) — مثال: 11111111,22222222
ADMINS=6526275367

# --- محدودیت‌ها ---
# حداکثر حجم فایل ارسالی به تلگرام بر حسب مگابایت (Telegram limit ~50MB for bots)
MAX_FILE_SIZE_MB=50
# حداکثر تعداد لینک در یک پیام کاربر
MAX_LINKS_PER_MESSAGE=5
# حداکثر دانلود هم‌زمان
MAX_CONCURRENT_DOWNLOADS=3

# --- Rate Limiting ---
# طول پنجره (ثانیه) و حداکثر تعداد درخواست در آن پنجره
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=10

# --- پراکسی (اختیاری) ---
# استفاده از پراکسی برای اتصال ربات و yt-dlp
USE_PROXY=false
# فرمت‌ها:  http://host:port   |   socks5://user:pass@host:port
PROXY_URL=

# --- yt-dlp ---
YTDLP_FORMAT=bestvideo*+bestaudio/best
# مسیر فایل کوکی برای دسترسی به محتوای خصوصی (مثلاً اینستاگرام لاگین‌شده)
YTDLP_COOKIEFILE=
YTDLP_RETRIES=3

# --- پلتفرم‌ها (اختیاری) ---
# رشته کوکی مرورگر اینستاگرام برای محتوای خصوصی/استوری
INSTAGRAM_COOKIE=

# --- عمومی ---
BOT_NAME=📥 Media Downloader
BOT_LANG=fa
LOG_LEVEL=INFO
